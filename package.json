{
  "name": "inrcy-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=9999",
    "verify:env": "node scripts/verify-env.mjs",
    "smoke:health": "node scripts/smoke-health.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install --with-deps",
    "typecheck": "tsc --noEmit --pretty false --noErrorTruncation",
    "test:multicompte": "node --test --experimental-strip-types tests/multicompte/*.test.mts",
    "audit:multicompte": "node scripts/audit-multicompte.mjs",
    "prebuild": "node scripts/prebuild-clean.mjs",
    "test:media-rules": "node --test tests/media-rules/media-rules.test.mjs",
    "qa:multicompte": "node scripts/qa-multicompte-final.mjs && node scripts/qa-multicompte-scope-lockdown.mjs && npm run test:multicompte",
    "test:booster-images": "node --test --experimental-strip-types tests/booster-image-decision/booster-image-decision.test.mts && node --test tests/booster-image-decision/*.test.mjs",
    "qa:booster-images": "npm run test:booster-images && npm run test:media-rules",
    "verify:pinterest-env": "node scripts/verify-pinterest-env.mjs",
    "qa:pinterest": "node scripts/qa-pinterest-standard.mjs && npm run verify:pinterest-env",
    "audit:ai-gateway": "node scripts/audit-ai-gateway.mjs",
    "test:ai-gateway": "node --test --experimental-strip-types tests/ai-gateway/*.test.mts",
    "qa:ai-gateway": "npm run audit:ai-gateway && npm run test:ai-gateway && npm run typecheck",
    "verify:ai-gateway-catalog": "node scripts/verify-ai-gateway-catalog.mjs",
    "qa:ai-gateway:live": "node scripts/qa-ai-gateway-live.mjs --mode=smoke",
    "qa:ai-gateway:final": "npm run audit:ai-gateway && npm run test:ai-gateway && npm run typecheck && npm run verify:ai-gateway-catalog",
    "qa:ai-gateway:matrix": "node scripts/qa-ai-gateway-live.mjs --mode=matrix",
    "qa:ai-gateway:full": "node scripts/qa-ai-gateway-live.mjs --mode=full",
    "qa:ai-gateway:calibrate": "node scripts/calibrate-ai-engines.mjs",
    "qa:ai-gateway:certify": "node scripts/qa-ai-gateway-live.mjs --mode=certify",
    "qa:inr-search": "node scripts/qa-inr-search.mjs",
    "qa:inr-search:final": "npm run qa:inr-search && npm run typecheck && eslint app/entreprises app/metiers app/secteurs app/api/inr-search lib/inrSearch*.ts app/dashboard/settings/_components/InrSearchSettingsContent.tsx --max-warnings=9999"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.39.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.90.1",
    "@upstash/ratelimit": "^2.0.5",
    "@upstash/redis": "^1.34.4",
    "ffmpeg-static": "^5.2.0",
    "heic-convert": "^2.1.0",
    "html2canvas": "^1.4.1",
    "imapflow": "^1.2.9",
    "jspdf": "^4.0.0",
    "next": "^16.1.6",
    "nodemailer": "^9.0.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sharp": "^0.34.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.1",
    "@tailwindcss/postcss": "^4",
    "@types/heic-convert": "^2.1.1",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.9",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "allowScripts": {
    "core-js@3.48.0": true,
    "ffmpeg-static@5.3.0": true,
    "sharp@0.34.5": true,
    "unrs-resolver@1.11.1": true,
    "@sentry/cli@2.58.6": true
  },
  "overrides": {
    "postcss": "8.5.19"
  }
}
